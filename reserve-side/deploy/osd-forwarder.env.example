# Config + secrets for the osd-forwarder service.
# Copy to /etc/osd-forwarder.env, fill in values, chmod 640. NEVER commit the real file.

# --- Gundi (primary output) ---
# API key from your Gundi connection: portal -> Connection -> Provider tab.
GUNDI_API_KEY=REPLACE_WITH_YOUR_GUNDI_CONNECTION_APIKEY
GUNDI_URL=https://sensors.api.gundiservice.org/v2/observations/
GUNDI_MODE=sensors
GUNDI_MIN_INTERVAL=2

# --- MQTT broker (the platform deployed by setup.sh, on the same host) ---
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_TLS=0
MQTT_USERNAME=dji
MQTT_PASSWORD=REPLACE_WITH_YOUR_BROKER_PASSWORD

# --- Optional: also post directly to EarthRanger (bypassing Gundi) ---
#ER_SITE=https://yoursite.pamdas.org
#ER_TOKEN=REPLACE_WITH_YOUR_EARTHRANGER_TOKEN
#POST_MIN_INTERVAL=1

PYTHONUNBUFFERED=1
